# این فایل را به اسم .env کپی کنید و مقادیر را عوض کنید
# رمز ورود پنل صندوق و مدیریت
PANEL_PASSWORD=cafe1234
# کلید امضای توکن — حتماً یک رشته تصادفی طولانی بگذارید
SECRET_KEY=change-me-to-a-long-random-string
# مدت اعتبار توکن (ساعت)
TOKEN_EXPIRE_HOURS=12
# آدرس فرانت برای CORS (اگر با پراکسی Vite اجرا می‌کنید نیازی به تغییر نیست)
CORS_ORIGINS=http://localhost:5173
